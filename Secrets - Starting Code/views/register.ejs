<%- include('partials/header') %>
<main class="auth-layout">
  <section class="auth-panel">
    <div class="auth-showcase">
      <span class="section-kicker">Join In</span>
      <h1>Create a space for honest stories.</h1>
      <p>Registration now feels like part of the same experience, not a plain form dropped onto the page.</p>
      <div class="auth-list">
        <div class="auth-list-item">Soft, editorial-style typography</div>
        <div class="auth-list-item">Clear contrast for form fields and actions</div>
        <div class="auth-list-item">Responsive layout that stays balanced on mobile</div>
      </div>
    </div>

    <div class="auth-form-wrap">
      <span class="section-kicker">Register</span>
      <h2 class="page-title">Start anonymously sharing</h2>
      <p class="page-subtitle">Create your account with a quick email and password.</p>
      <div class="card">
        <div class="card-body">
          <form action="/register" method="POST">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" class="form-control" name="username" placeholder="you@example.com">
            </div>
            <div class="form-group">
              <label for="password">Password</label>
              <input type="password" class="form-control" name="password" placeholder="Create a password">
            </div>
            <button type="submit" class="btn btn-dark btn-lg">Register</button>
          </form>

          <div class="divider-section">
            <span class="divider-text">Or sign up with</span>
          </div>

          <a href="/auth/google" class="btn btn-google btn-lg">
            <i class="fab fa-google"></i> Sign up with Google
          </a>

          <p class="form-note">Already have an account? <a href="/login">Log in</a>.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
