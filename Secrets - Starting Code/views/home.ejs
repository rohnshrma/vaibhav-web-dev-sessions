<%- include('partials/header') %>

<main class="app-shell">
  <section class="hero-panel">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="brand-mark">
          <i class="fas fa-key"></i>
        </div>
        <h1 class="display-3">Secrets</h1>
        <p class="lead">A warmer, calmer place to share what you could never say out loud, without ever attaching your name to it.</p>
        <div class="hero-actions">
          <a class="btn btn-dark btn-lg" href="/register" role="button">Create Account</a>
          <a class="btn btn-light btn-lg" href="/login" role="button">Log In</a>
        </div>
        <p class="hero-note">Anonymous submissions. Simple sign in. No clutter.</p>
      </div>

      <div class="hero-card">
        <h2>Built for quiet honesty.</h2>
        <p>The app is still lightweight, but the experience now feels more intentional and polished from the first screen onward.</p>
        <div class="hero-points">
          <div class="hero-point">
            <i class="fas fa-user-secret"></i>
            <span>Share sensitive thoughts without public identity.</span>
          </div>
          <div class="hero-point">
            <i class="fas fa-lock"></i>
            <span>Move from sign up to submission through one consistent interface.</span>
          </div>
          <div class="hero-point">
            <i class="fas fa-feather-alt"></i>
            <span>Soft contrast and spacious layout make the app easier to read.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
