<%- include('partials/header') %>

<main class="submit-layout">
  <section class="submit-panel">
    <div class="panel-icon">
      <i class="fas fa-key"></i>
    </div>
    <h1 class="page-title">Share your secret</h1>
    <p class="page-subtitle">Type what you want to say and send it into the vault without attaching your identity.</p>

    <form action="/submit" method="POST" class="submit-form">
      <div class="form-group">
        <input type="text" class="form-control" name="secret" placeholder="What's your secret?">
      </div>
      <button type="submit" class="btn btn-dark btn-lg">Submit Secret</button>
    </form>
  </section>
</main>
<%- include('partials/footer') %>
