<%- include('partials/header') %>

<main class="auth-layout">
  <section class="auth-panel">
    <div class="auth-showcase">
      <span class="section-kicker">Welcome Back</span>
      <h1>Step back into the vault.</h1>
      <p>Pick up where you left off and continue exploring anonymous stories in a cleaner, more immersive interface.</p>
      <div class="auth-list">
        <div class="auth-list-item">Smooth, focused form layout</div>
        <div class="auth-list-item">Consistent visual language across every page</div>
        <div class="auth-list-item">Optimized spacing for desktop and mobile</div>
      </div>
    </div>

    <div class="auth-form-wrap">
      <span class="section-kicker">Login</span>
      <h2 class="page-title">Access your account</h2>
      <p class="page-subtitle">Use your email and password to continue.</p>
      <div class="card">
        <div class="card-body">
          <form action="/login" method="POST">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" class="form-control" name="username" placeholder="you@example.com">
            </div>
            <div class="form-group">
              <label for="password">Password</label>
              <input type="password" class="form-control" name="password" placeholder="Enter your password">
            </div>
            <button type="submit" class="btn btn-dark btn-lg">Login</button>
          </form>
          <p class="form-note">New here? <a href="/register">Create an account</a>.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
