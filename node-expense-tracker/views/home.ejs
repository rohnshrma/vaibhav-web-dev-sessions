<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Expense Tracker Starter Kit</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <span class="eyebrow">Expense Tracker</span>
        <h1>Track spending with a clean, modern layout.</h1>
      </section>

      <section class="grid">
        <article class="card">
          <h2>Add Expense</h2>

          <!--
            This form is rendered by the server and shown in the browser.

            This form sends a POST request to /add-expense.
            The `name` attributes are the keys Express receives inside req.body.

            Example after submit:
            - input name="name" -> req.body.name
            - input name="amount" -> req.body.amount
          -->
          <form class="expense-form" action="/add-expense" method="POST">
            <div class="field">
              <label for="name">Expense Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Groceries"
              />
            </div>

            <div class="field">
              <label for="amount">Amount</label>
              <input
                type="number"
                id="amount"
                name="amount"
                placeholder="250"
                min="0"
                step="0.01"
              />
            </div>

            <button class="primary-btn" type="submit">Add Expense</button>
          </form>
        </article>

        <article class="card">
          <h2>Expense List</h2>

          <div class="summary">
            <div>
              <!--
                `total` is calculated in server.js and passed into this template by:
                res.render("home", { expenses, total })

                EJS can access those variables directly.
              -->
              <div class="summary-label">Total Expenses</div>
              <div class="summary-value">₹ <%= total %></div>
            </div>
            <%#
            <div class="summary-note">Students will make this dynamic</div>
            %>
          </div>

          <% /*
            EJS lets us write JavaScript logic inside HTML.
            This condition checks whether the `expenses` array has any items.

            If expenses exist:
            - show the list
            Otherwise:
            - show the empty state message
          */ %>
          <% if(expenses.length > 0){ %>

          <ul class="expense-list">
            <% /*
              `forEach` loops through every expense object in the array.
              For each expense, EJS repeats the HTML below one time.
            */ %>
            <% expenses.forEach(expenseObj =>{ %>

            <li class="expense-item">
              <div class="expense-meta">
                <!--
                  `<%=` prints a JavaScript value into the HTML output.
                  So the expense name stored in MongoDB becomes visible on the page.
                -->
                <span class="expense-name"><%= expenseObj.name %></span>

                <%#<span class="expense-caption"
                  >This is placeholder content</span
                >
                %>
              </div>

              <div class="expense-actions">
                <span class="expense-amount">₹ <%= expenseObj.amount %></span>

                <!--
                  This delete form sends a POST request to a dynamic URL.
                  Example:
                  - if `_id` is 123
                  - form action becomes `/delete/123`

                  In Express, that value is available as `req.params.id`.
                -->
                <form action="/delete/<%= expenseObj._id %>" method="POST">
                  <button class="delete-btn" type="submit">Delete</button>
                </form>
              </div>
            </li>

            <% }) %>
          </ul>

          <% }else{ %>
          <div class="empty-state">No Expenses Yet! Add One.</div>
          <% } %>
        </article>
      </section>
    </main>
  </body>
</html>
